{
  "name": "focloir-poca",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "build:android": "BUILD_TARGET=mobile VITE_API_BASE=https://focloir.athbheochan.irish vite build && npx cap sync android",
    "build:ios": "BUILD_TARGET=mobile VITE_API_BASE=https://focloir.athbheochan.irish vite build && npx cap sync ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@sentry/sveltekit": "^10.57.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "bits-ui": "^2.18.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "lucide-svelte": "^1.0.1",
    "tailwind-merge": "^3.6.0"
  }
}
